        "fast": {
          "temperature": 0.3,
          "num_predict": 2048,
          "num_ctx": 8192
        },
        "balanced": {
          "temperature": 0.4,
          "num_predict": 4096,
          "num_ctx": 8192
        },
        "ui-heavy": {
          "temperature": 0.5,
          "num_predict": 8192,
          "num_ctx": 12288
        },
        "tools": {
          "temperature": 0.3,
          "num_predict": 8192,
          "num_ctx": 16384
        }
