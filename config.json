{
  "concurrency": 3,
  "leaseMs": 1800000,
  "providers": {
    "claude": {
      "enabled": true,
      "capabilities": [
        "file_edit",
        "shell_exec",
        "code_review",
        "streaming",
        "long_context"
      ],
      "transport": "subprocess",
      "command": "claude",
      "baseArgs": [
        "-p",
        "--output-format",
        "stream-json",
        "--verbose"
      ],
      "extraArgs": [],
      "permissionModes": {
        "safe": [
          "--permission-mode",
          "acceptEdits"
        ],
        "full": [
          "--permission-mode",
          "bypassPermissions"
        ],
        "_comment": "safe=แก้ไฟล์ได้แต่ Bash ถูก block, full=ทำได้ทุกอย่าง (รัน test/build). เลือกต่อ task ผ่าน routing หรือ UI"
      },
      "defaultPermission": "safe",
      "accountEnv": "CLAUDE_CONFIG_DIR",
      "rotation": "failover",
      "accounts": [
        {
          "id": "claude-1",
          "configDir": "~/.claude"
        }
      ],
      "auth": {
        "mode": "plan",
