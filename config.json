      },
      "tiers": {
        "opus": "opus",
        "sonnet": "sonnet",
        "haiku": "haiku"
      }
    },
    "ollama": {
      "enabled": true,
      "capabilities": [
        "text_gen",
        "file_edit",
        "code_review"
      ],
      "transport": "http",
      "host": "http://127.0.0.1:11434",
      "think": false,
      "tools": true,
      "toolsMaxIter": 20,
      "keepAlive": "30m",
      "defaultProfile": "balanced",
