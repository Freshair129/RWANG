{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "G-Orchestra",
  "version": "0.1.0",
  "identifier": "com.gmaiden.orchestra",
  "build": {
    "beforeDevCommand": "pnpm -C studio dev",
    "devUrl": "http://localhost:5599",
    "beforeBuildCommand": "pnpm -C studio build",
    "frontendDist": "../studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "G-Orchestra — Mission Control",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:*; script-src 'self' 'wasm-unsafe-eval' http://localhost:*; img-src 'self' data:; connect-src 'self' http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
